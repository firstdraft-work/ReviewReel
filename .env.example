# Local development
TTS_PROVIDER=system
FFMPEG_PATH=ffmpeg

# Temporary escape hatch for Vercel preview experiments only.
# Production should keep this unset and use Blob + cloud TTS + remote rendering.
ALLOW_LOCAL_MEDIA_ON_VERCEL=

# Vercel production target:
# Use Vercel Blob for uploaded images and generated media URLs.
STORAGE_PROVIDER=blob
BLOB_READ_WRITE_TOKEN=

# Use an external renderer for FFmpeg/video composition in production.
VIDEO_RENDERER_URL=
VIDEO_RENDERER_TOKEN=

# Use a cloud TTS provider in production instead of macOS `say`.
# Example future value: TTS_PROVIDER=cloud
TTS_ENDPOINT_URL=
TTS_API_KEY=
